{
  "name": "frontend",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config src/proxy.conf.json",
    "deploy":"npm run build && npm run nginx:limpiar && npm run nginx:llenar",
    "nginx:limpiar": "del /F /Q C:\\nginx-1.28.2\\html\\* && for /d %x in (C:\\nginx-1.28.2\\html\\*) do rmdir /S /Q \"%x\"",
    "nginx:llenar":"xcopy /E /I dist\\frontend\\browser\\* C:\\nginx-1.28.2\\html\\",
    "deploy-linux": "npm run build && npm run nginx:limpiar-linux && npm run nginx:llenar-linux",
    "nginx:limpiar-linux": "rm -rf /usr/share/nginx/html/*",
    "nginx:llenar-linux": "cp -r dist/frontend/browser/* /usr/share/nginx/html/",
    "build": "ng build"
  },
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "chart.js": "^4.5.1",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/node": "^22.0.0",
    "typescript": "~5.6.0"
  }
}
